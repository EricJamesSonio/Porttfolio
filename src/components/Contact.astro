---
<section id="contact" class="contact-section fade-in">
  <h2>Contact Me</h2>
  <p class="section-intro">
    Have a question, collaboration idea, or project opportunity? I'd love to hear from you.
  </p>

  <div class="contact-container">

    <div class="contact-form" id="contactForm">
      <div>
        <label for="name">Name</label>
        <input type="text" id="name" required placeholder="Your Name" />
      </div>
      <div>
        <label for="email">Email</label>
        <input type="email" id="email" required placeholder="your@email.com" />
      </div>
      <div>
        <label for="message">Message</label>
        <textarea id="message" rows="6" required placeholder="Write your message..."></textarea>
      </div>
      <button id="sendBtn"><span>Send Message</span></button>
      <p id="formMessage"></p>
    </div>

    <div class="contact-info">
      <h3>Let's Connect</h3>
      <p><strong>Email:</strong> ericjamessonio7@gmail.com</p>
      <p><strong>Phone:</strong> 0968 763 7694</p>
      <p><strong>Location:</strong> Pandi, Bulacan</p>
      <div class="socials">
        <a href="https://github.com/EricJamesSonio" target="_blank" class="social-icon">GitHub</a>
        <a href="https://www.linkedin.com/in/eric-james-sonio-32ba08365/" target="_blank" class="social-icon">LinkedIn</a>
        <a href="mailto:ericjamessonio7@gmail.com" class="social-icon">Email</a>
      </div>
    </div>

  </div>
</section>

<!-- Load EmailJS then init the form — is:inline prevents Astro from deferring/bundling this -->
<script is:inline>
  (function loadEmailJS() {
    const script = document.createElement('script');
    script.src = 'https://cdn.jsdelivr.net/npm/@emailjs/browser@4/dist/email.min.js';
    script.onload = function () {
      emailjs.init('ZMSS1LVAAfJWzhQQR');

      const sendBtn     = document.getElementById('sendBtn');
      const formMessage = document.getElementById('formMessage');

      if (!sendBtn) return;

      sendBtn.addEventListener('click', function () {
        const nameEl    = document.getElementById('name');
        const emailEl   = document.getElementById('email');
        const messageEl = document.getElementById('message');

        // Basic validation since we dropped the <form>
        if (!nameEl.value.trim() || !emailEl.value.trim() || !messageEl.value.trim()) {
          formMessage.textContent = '⚠️ Please fill in all fields.';
          formMessage.style.color = 'white';
          formMessage.style.backgroundColor = 'rgba(234, 179, 8, 0.3)';
          formMessage.style.padding = '0.75rem';
          formMessage.style.borderRadius = '0.5rem';
          formMessage.style.display = 'block';
          return;
        }

        const originalText = sendBtn.textContent;
        sendBtn.textContent = 'Sending...';
        sendBtn.disabled = true;

        const templateParams = {
          from_name:  nameEl.value,
          from_email: emailEl.value,
          message:    messageEl.value,
        };

        emailjs.send('service_c4zldhl', 'template_khkbo9r', templateParams)
          .then(() => {
            formMessage.textContent = '✅ Message sent successfully!';
            formMessage.style.color = 'white';
            formMessage.style.backgroundColor = 'rgba(34, 197, 94, 0.3)';
            formMessage.style.padding = '0.75rem';
            formMessage.style.borderRadius = '0.5rem';
            formMessage.style.display = 'block';
            nameEl.value    = '';
            emailEl.value   = '';
            messageEl.value = '';
            sendBtn.textContent = originalText;
            sendBtn.disabled = false;
            setTimeout(() => { formMessage.style.display = 'none'; }, 5000);
          })
          .catch((error) => {
            formMessage.textContent = '❌ Failed to send message. Please try again later.';
            formMessage.style.color = 'white';
            formMessage.style.backgroundColor = 'rgba(239, 68, 68, 0.3)';
            formMessage.style.padding = '0.75rem';
            formMessage.style.borderRadius = '0.5rem';
            formMessage.style.display = 'block';
            sendBtn.textContent = originalText;
            sendBtn.disabled = false;
            console.error('EmailJS Error:', error);
          });
      });
    };
    document.head.appendChild(script);
  })();
</script>